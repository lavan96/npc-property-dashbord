# Copy this file to .pdf-sidecar.env beside deploy_pdf_sidecar.sh.
# Never commit the populated file if it contains private paths or identifiers.

# Required Google Cloud context.
PROJECT_ID="your-gcp-project-id"
REGION="australia-southeast1"
SERVICE="pdf-parse-service"

# Local or Cloud Shell checkout of npc-property-dashbord.
REPO_ROOT="$HOME/npc-property-dashbord"
SIDECAR_DIR="pdf-parse-service"

# Leave blank to derive the repository from the image currently used by Cloud Run.
# Artifact Registry example:
# IMAGE_REPO="australia-southeast1-docker.pkg.dev/your-gcp-project/pdf-services/pdf-parse-service"
IMAGE_REPO=""

# Leave blank for an automatically generated unique lowercase tag.
CANARY_TAG=""

# Recommended: the Secret Manager secret bound to PDF_PARSE_SERVICE_TOKEN.
# The script can often discover this automatically from the Cloud Run service.
TOKEN_SECRET_NAME=""

# Use a small, approved, non-client PDF accessible to Cloud Run.
# The script sends this URL to /plan to verify Plan V2.
SMOKE_PDF_URL=""
SMOKE_MODE="hybrid"

# Optional: set to 1 to run a synchronous /parse smoke test after /plan.
# This is slower and should use a very small PDF.
RUN_PARSE_SMOKE="0"

# Optional repository-side test command, run before the image is built.
# SIDECAR_TEST_CMD="python3 -m unittest discover -s pdf-parse-service/tests -p 'test_*.py'"
SIDECAR_TEST_CMD=""

# Safety controls.
ALLOW_DIRTY="0"
DRY_RUN="0"

# Optional persistent release evidence directory.
STATE_ROOT="$HOME/.pdf-sidecar-releases"
