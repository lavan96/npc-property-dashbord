{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://npcservices.com.au/schemas/pdf-import/import-intelligence-profile.schema.json",
  "title": "PDF Import Intelligence Profile",
  "description": "Deterministic classification of a PDF import. Metadata only — never stores raw PDF text or private extracted content.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "importId",
    "templateId",
    "profileCategory",
    "riskLevel",
    "confidence",
    "scores",
    "signals",
    "recommendations",
    "evidence",
    "warnings",
    "blockers",
    "generatedAt"
  ],
  "properties": {
    "version": { "type": "string", "const": "pdf-import-intelligence-profile-v1" },
    "importId": { "type": ["string", "null"] },
    "templateId": { "type": ["string", "null"] },
    "sourceFilename": { "type": ["string", "null"] },
    "profileCategory": {
      "type": "string",
      "enum": [
        "simple_document",
        "design_heavy",
        "multi_page_report",
        "table_heavy",
        "image_heavy",
        "scanned_ocr",
        "mixed_complex",
        "high_risk",
        "unknown"
      ]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical", "unknown"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "complexityScore",
        "ocrRiskScore",
        "tableRiskScore",
        "imageRiskScore",
        "designRiskScore",
        "automationRiskScore",
        "manualReviewLikelihood",
        "confidence"
      ],
      "properties": {
        "complexityScore": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "ocrRiskScore": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "tableRiskScore": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "imageRiskScore": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "designRiskScore": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "automationRiskScore": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "manualReviewLikelihood": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "signals": {
      "type": "object",
      "description": "Structured signals. Booleans/numbers/strings/null only — no raw document text.",
      "additionalProperties": true
    },
    "recommendations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "visualQaStrategy",
        "repairStrategy",
        "aiReconciliationStrategy",
        "exportParityStrategy",
        "operatorStrategy"
      ],
      "properties": {
        "visualQaStrategy": {
          "type": "string",
          "enum": ["required", "recommended", "optional", "not_required"]
        },
        "repairStrategy": {
          "type": "string",
          "enum": ["allow", "allow_with_review", "skip", "manual_only", "blocked"]
        },
        "aiReconciliationStrategy": {
          "type": "string",
          "enum": ["not_needed", "optional", "recommended", "manual_review", "blocked"]
        },
        "exportParityStrategy": {
          "type": "string",
          "enum": ["required", "recommended", "manual_required", "optional", "not_required"]
        },
        "operatorStrategy": {
          "type": "string",
          "enum": ["proceed", "review_before_apply", "manual_review_required", "block_until_review", "rerun_import"]
        }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "label", "value", "weight", "message"],
        "properties": {
          "code": { "type": "string" },
          "label": { "type": "string" },
          "value": { "type": ["string", "number", "boolean", "null"] },
          "weight": { "type": "number" },
          "message": { "type": "string" }
        }
      }
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "generatedAt": { "type": "string" }
  }
}
