{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://npcservices.com.au/schemas/pdf-import/golden-corpus-registry.schema.json",
  "title": "PDF Import Golden Corpus Registry",
  "description": "Schema for the Phase 8A golden corpus registry. Defines canonical PDF categories used for repeatable PDF import regression testing. Does not reference or embed private PDFs.",
  "type": "object",
  "required": ["version", "registryName", "description", "updatedAt", "corpus"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "const": "pdf-import-golden-corpus-registry-v1"
    },
    "registryName": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "updatedAt": {
      "type": "string",
      "description": "ISO-8601 timestamp of last registry edit, or empty string in the committed template."
    },
    "corpus": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/corpusItem" }
    }
  },
  "definitions": {
    "corpusItem": {
      "type": "object",
      "required": [
        "corpusId",
        "category",
        "title",
        "purpose",
        "pageCountExpectation",
        "expectedOutcomes",
        "scoreThresholds",
        "acceptableWarnings",
        "unacceptableFailures",
        "requiredMetadata",
        "notes"
      ],
      "additionalProperties": false,
      "properties": {
        "corpusId": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "simple_one_page",
            "design_heavy_one_page",
            "multi_page_report",
            "table_heavy",
            "image_heavy",
            "scanned_ocr"
          ]
        },
        "title": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "pageCountExpectation": { "$ref": "#/definitions/pageCountExpectation" },
        "expectedOutcomes": { "$ref": "#/definitions/expectedOutcomes" },
        "scoreThresholds": { "$ref": "#/definitions/scoreThresholds" },
        "acceptableWarnings": { "type": "array", "items": { "type": "string" } },
        "unacceptableFailures": { "type": "array", "items": { "type": "string" } },
        "requiredMetadata": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "pageCountExpectation": {
      "type": "object",
      "required": ["mode", "exact", "minimum", "maximum"],
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["exact", "minimum", "range", "unknown"]
        },
        "exact": { "type": ["number", "null"] },
        "minimum": { "type": ["number", "null"] },
        "maximum": { "type": ["number", "null"] }
      }
    },
    "expectedOutcomes": {
      "type": "object",
      "required": [
        "importShouldSucceed",
        "templateShouldBeCreated",
        "visualQaShouldRun",
        "repairShouldRunOrSkipSafely",
        "applyRepairShouldOpenEditor",
        "exportParityShouldBeRecordable",
        "templatePageCountShouldMatch",
        "manualReviewAllowed",
        "fallbackAllowed"
      ],
      "additionalProperties": false,
      "properties": {
        "importShouldSucceed": { "type": "boolean" },
        "templateShouldBeCreated": { "type": "boolean" },
        "visualQaShouldRun": { "type": "boolean" },
        "repairShouldRunOrSkipSafely": { "type": "boolean" },
        "applyRepairShouldOpenEditor": { "type": "boolean" },
        "exportParityShouldBeRecordable": { "type": "boolean" },
        "templatePageCountShouldMatch": { "type": "boolean" },
        "manualReviewAllowed": { "type": "boolean" },
        "fallbackAllowed": { "type": "boolean" }
      }
    },
    "scoreThresholds": {
      "type": "object",
      "required": ["visualQaMinimum", "repairFinalMinimum", "exportParityMinimum"],
      "additionalProperties": false,
      "properties": {
        "visualQaMinimum": { "type": "number", "minimum": 0, "maximum": 1 },
        "repairFinalMinimum": { "type": "number", "minimum": 0, "maximum": 1 },
        "exportParityMinimum": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
