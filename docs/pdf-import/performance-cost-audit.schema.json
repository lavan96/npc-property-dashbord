{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://npcservices.com.au/schemas/pdf-import/performance-cost-audit.schema.json",
  "title": "PDF Import Performance + Cost Audit",
  "description": "Advisory performance/cost optimization audit. Metadata only — never skips quality gates, calls AI, mutates templates, or stores raw PDF/OCR text or rasters.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "importId",
    "templateId",
    "sourceFilename",
    "overallCostLevel",
    "overallRiskLevel",
    "estimatedCostScore",
    "estimatedWasteScore",
    "recommendations",
    "stepCosts",
    "staleness",
    "duplicateWork",
    "warnings",
    "blockers",
    "generatedAt"
  ],
  "definitions": {
    "costLevel": {
      "type": "string",
      "enum": ["negligible", "low", "medium", "high", "very_high", "unknown"]
    },
    "riskLevel": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical", "unknown"]
    },
    "domain": {
      "type": "string",
      "enum": [
        "artifact_fetch", "visual_qa", "repair", "ai_reconciliation", "export_parity",
        "golden_regression", "metadata", "diagnostics", "ui_dashboard", "storage"
      ]
    },
    "action": {
      "type": "string",
      "enum": [
        "no_action", "reuse_existing_result", "rebuild_stale_metadata", "defer_expensive_step",
        "require_operator_confirmation", "compact_metadata", "limit_query_scope", "cache_artifact_lookup",
        "rerun_only_if_inputs_changed", "avoid_ai_reconciliation", "require_manual_review_before_costly_step",
        "inspect_long_running_job", "inspect_storage_artifacts", "archive_or_prune_old_history", "document_manual_gap"
      ]
    },
    "evidenceItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "label", "value", "weight", "message"],
      "properties": {
        "code": { "type": "string" },
        "label": { "type": "string" },
        "value": { "type": ["string", "number", "boolean", "null"] },
        "weight": { "type": "number" },
        "message": { "type": "string" }
      }
    },
    "recommendation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "domain", "action", "severity", "costLevel", "confidence", "message", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "domain": { "$ref": "#/definitions/domain" },
        "action": { "$ref": "#/definitions/action" },
        "severity": { "type": "string", "enum": ["info", "low", "medium", "high", "critical"] },
        "costLevel": { "$ref": "#/definitions/costLevel" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "message": { "type": "string" },
        "evidence": { "type": "array", "items": { "$ref": "#/definitions/evidenceItem" } }
      }
    },
    "stepCost": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stepId", "label", "domain", "costLevel", "estimatedCostScore", "shouldRequireConfirmation", "canReuseExistingResult", "reason"],
      "properties": {
        "stepId": { "type": "string" },
        "label": { "type": "string" },
        "domain": { "$ref": "#/definitions/domain" },
        "costLevel": { "$ref": "#/definitions/costLevel" },
        "estimatedCostScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "shouldRequireConfirmation": { "type": "boolean" },
        "canReuseExistingResult": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "staleness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metadataKey", "status", "reason", "generatedAt", "dependsOn"],
      "properties": {
        "metadataKey": { "type": "string" },
        "status": { "type": "string", "enum": ["fresh", "stale", "missing", "unknown", "not_applicable"] },
        "reason": { "type": "string" },
        "generatedAt": { "type": ["string", "null"] },
        "dependsOn": { "type": "array", "items": { "type": "string" } }
      }
    },
    "duplicateWork": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "count", "message"],
      "properties": {
        "code": { "type": "string" },
        "count": { "type": "number" },
        "message": { "type": "string" }
      }
    }
  },
  "properties": {
    "version": { "type": "string", "const": "pdf-import-performance-cost-audit-v1" },
    "importId": { "type": ["string", "null"] },
    "templateId": { "type": ["string", "null"] },
    "sourceFilename": { "type": ["string", "null"] },
    "overallCostLevel": { "$ref": "#/definitions/costLevel" },
    "overallRiskLevel": { "$ref": "#/definitions/riskLevel" },
    "estimatedCostScore": { "type": "number", "minimum": 0, "maximum": 1 },
    "estimatedWasteScore": { "type": "number", "minimum": 0, "maximum": 1 },
    "signals": { "type": "object" },
    "stepCosts": { "type": "array", "items": { "$ref": "#/definitions/stepCost" } },
    "staleness": { "type": "array", "items": { "$ref": "#/definitions/staleness" } },
    "duplicateWork": { "type": "array", "items": { "$ref": "#/definitions/duplicateWork" } },
    "recommendations": { "type": "array", "items": { "$ref": "#/definitions/recommendation" } },
    "evidence": { "type": "array", "items": { "$ref": "#/definitions/evidenceItem" } },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "blockers": { "type": "array", "items": { "type": "string" } },
    "generatedAt": { "type": "string" },
    "persistedAt": { "type": ["string", "null"] }
  }
}
